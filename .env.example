# GitHub Personal Access Token (needs repo, actions:read scopes)
GITHUB_TOKEN=ghp_your_token_here

# GitHub organization (optional - if empty, collects from user's repos)
GITHUB_ORG=

# Comma-separated list of repos to monitor (optional - if empty and org set, collects all org repos)
# Example: owner/repo1,owner/repo2
COLLECT_REPOS=

# Database
DATABASE_URL=sqlite:///./pipeline_optimizer.db

# Server
PORT=8100
HOST=0.0.0.0

# Anthropic API key (for AI agent recommendations)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# AI model for generating recommendations
AGENT_MODEL=claude-sonnet-5

# How often to re-collect data (hours)
CACHE_DURATION_HOURS=1
